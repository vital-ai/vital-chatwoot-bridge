# Vital Chatwoot Bridge - Local Development Environment
# Generated by scripts/set_config_env.py

# Logging Configuration
LOG_LEVEL="INFO"

# Chatwoot Configuration
CHATWOOT_BASE_URL="http://localhost:9000"
CHATWOOT_API_ACCESS_TOKEN="test-token-123"
CHATWOOT_ACCOUNT_ID="1"
CHATWOOT_BOT_WEBHOOK_SECRET="webhook-secret"
ENFORCE_WEBHOOK_SIGNATURES="true"

# Keycloak Configuration for JWT Authentication
KEYCLOAK_REALM="your-realm"
KEYCLOAK_CLIENT_ID="your-client-id"
KEYCLOAK_CLIENT_SECRET="your-client-secret"
KEYCLOAK_USER="your-username"
KEYCLOAK_PASSWORD="your-password"
KEYCLOAK_BASE_URL="http://host.docker.internal:8085"

# Inbox → Agent Mappings (CW_BRIDGE__inbox_agents__<inbox_id>__<field>)
CW_BRIDGE__inbox_agents__1__agent_id=agent_1
CW_BRIDGE__inbox_agents__1__websocket_url=ws://localhost:8085
CW_BRIDGE__inbox_agents__1__timeout_seconds=30
CW_BRIDGE__inbox_agents__2__agent_id=agent_2
CW_BRIDGE__inbox_agents__2__websocket_url=ws://localhost:8086
CW_BRIDGE__inbox_agents__2__timeout_seconds=45

# CORS Configuration (comma-separated origins, default "*")
# CORS_ALLOWED_ORIGINS="https://dashboard.example.com,https://admin.example.com"

# LoopMessage API Configuration
LOOPMESSAGE_API_URL="https://server.loopmessage.com/api/v1"
LOOPMESSAGE_AUTHORIZATION_KEY="your-authorization-key"
LOOPMESSAGE_SECRET_KEY="your-secret-key"
LOOPMESSAGE_SENDER_NAME="your-sender@a.imsg.co"

# API Inbox Integrations (CW_BRIDGE__api_inboxes__<type>__<field>)
CW_BRIDGE__api_inboxes__loopmessage__inbox_identifier=your-inbox-identifier
CW_BRIDGE__api_inboxes__loopmessage__chatwoot_inbox_id=2
CW_BRIDGE__api_inboxes__loopmessage__name=LoopMessage iMessages
CW_BRIDGE__api_inboxes__loopmessage__message_types=imessage
CW_BRIDGE__api_inboxes__loopmessage__contact_identifier_field=phone_number
CW_BRIDGE__api_inboxes__loopmessage__supports_outbound=true

# Client Test Configuration
BRIDGE_BASE_URL="http://localhost:8009"
KEYCLOAK_CLIENT_BASE_URL="http://localhost:8085"
TEST_SMS_RECIPIENT=""
TEST_EMAIL_RECIPIENT=""
TEST_CONTACT_NAME="Test User"
TEST_LOOPMESSAGE_INBOX_ID=""
TEST_LOOPMESSAGE_PHONE=""

# Timeout Configuration
DEFAULT_RESPONSE_TIMEOUT="30"
WEBSOCKET_CONNECT_TIMEOUT="10"
WEBSOCKET_PING_INTERVAL="30"
WEBSOCKET_PING_TIMEOUT="10"
