# Vital Chatwoot Bridge - Environment Configuration
# All config uses CW_BRIDGE__ prefix with __ separators.

# -- App (CW_BRIDGE__app__*) --
CW_BRIDGE__app__log_level=INFO
CW_BRIDGE__app__log_format=text
CW_BRIDGE__app__environment=development
CW_BRIDGE__app__port=8000
CW_BRIDGE__app__host=0.0.0.0
# CW_BRIDGE__app__cors_allowed_origins=https://dashboard.example.com,https://admin.example.com

# -- Chatwoot (CW_BRIDGE__chatwoot__*) --
CW_BRIDGE__chatwoot__base_url=http://localhost:9000
CW_BRIDGE__chatwoot__user_access_token=your-user-access-token
CW_BRIDGE__chatwoot__account_id=1
CW_BRIDGE__chatwoot__enforce_webhook_signatures=true

# -- Bots (CW_BRIDGE__bots__<name>__*) --
# Each bot has its own access_token from Chatwoot (used for webhook HMAC verification)
CW_BRIDGE__bots__default__access_token=your-bot-access-token
CW_BRIDGE__bots__default__name=Default Bot

# -- Inbox → Agent Mappings (CW_BRIDGE__inbox_agents__<inbox_id>__*) --
CW_BRIDGE__inbox_agents__1__agent_id=agent_1
CW_BRIDGE__inbox_agents__1__websocket_url=http://localhost:6006
CW_BRIDGE__inbox_agents__1__timeout_seconds=30
CW_BRIDGE__inbox_agents__1__bot=default
CW_BRIDGE__inbox_agents__2__agent_id=agent_2
CW_BRIDGE__inbox_agents__2__websocket_url=http://localhost:6007
CW_BRIDGE__inbox_agents__2__timeout_seconds=45
CW_BRIDGE__inbox_agents__2__bot=default

# -- Keycloak (CW_BRIDGE__keycloak__*) --
CW_BRIDGE__keycloak__base_url=http://host.docker.internal:8085
CW_BRIDGE__keycloak__realm=your-realm
CW_BRIDGE__keycloak__client_id=your-client-id
CW_BRIDGE__keycloak__client_secret=your-client-secret
CW_BRIDGE__keycloak__user=your-username
CW_BRIDGE__keycloak__password=your-password
CW_BRIDGE__keycloak__allowed_azps=cardiff-admin-portal-bff,cardiff-rest-service

# -- LoopMessage (CW_BRIDGE__loopmessage__*) --
CW_BRIDGE__loopmessage__api_url=https://server.loopmessage.com/api/v1
CW_BRIDGE__loopmessage__authorization_key=your-authorization-key
CW_BRIDGE__loopmessage__secret_key=your-secret-key
CW_BRIDGE__loopmessage__sender_name=your-sender@a.imsg.co

# -- Timeouts (CW_BRIDGE__timeouts__*) --
CW_BRIDGE__timeouts__response=30
CW_BRIDGE__timeouts__max_sync=25

# -- WebSocket (CW_BRIDGE__websocket__*) --
CW_BRIDGE__websocket__connect_timeout=10
CW_BRIDGE__websocket__ping_interval=30
CW_BRIDGE__websocket__ping_timeout=10
CW_BRIDGE__websocket__max_reconnect_attempts=5

# -- AWS (CW_BRIDGE__aws__*) --
CW_BRIDGE__aws__access_key_id=your-aws-access-key-id
CW_BRIDGE__aws__secret_access_key=your-aws-secret-access-key
CW_BRIDGE__aws__region=us-east-1

# -- Mailgun (CW_BRIDGE__mailgun__*) --
CW_BRIDGE__mailgun__api_key=your-mailgun-api-key
CW_BRIDGE__mailgun__domain=mg.example.com
CW_BRIDGE__mailgun__from_email=agent@mg.example.com
# CW_BRIDGE__mailgun__base_url=https://api.mailgun.net/v3

# -- API Inbox Integrations (CW_BRIDGE__api_inboxes__<type>__*) --
CW_BRIDGE__api_inboxes__loopmessage__inbox_identifier=your-inbox-identifier
CW_BRIDGE__api_inboxes__loopmessage__chatwoot_inbox_id=2
CW_BRIDGE__api_inboxes__loopmessage__name=LoopMessage iMessages
CW_BRIDGE__api_inboxes__loopmessage__message_types=imessage
CW_BRIDGE__api_inboxes__loopmessage__contact_identifier_field=phone_number
CW_BRIDGE__api_inboxes__loopmessage__supports_outbound=true

# -- Google / Gmail (CW_BRIDGE__google__*) --
# Service account key JSON (entire JSON string, not a file path)
# CW_BRIDGE__google__service_account_json={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# Whitelisted senders — only these emails can be impersonated
# CW_BRIDGE__google__senders__sales1__email=sender@example.com
# CW_BRIDGE__google__senders__sales1__display_name=Sales Rep
# CW_BRIDGE__google__senders__sales1__reply_to=sender@example.com
# CW_BRIDGE__google__senders__sales1__default_inbox_id=4
# Open/click tracking (template-only)
# CW_BRIDGE__google__tracking__pixel_url=https://tracking.example.com/pixel
# CW_BRIDGE__google__tracking__click_url=https://tracking.example.com/click
# CW_BRIDGE__google__tracking__default_campaign=default

# -- Rate Limiting (CW_BRIDGE__rate_limiting__*) --
# Queue backend: "memory" (default, per-task) or "redis" (shared, durable)
CW_BRIDGE__rate_limiting__queue_backend=memory
# Redis URL — required when queue_backend=redis
# CW_BRIDGE__rate_limiting__redis_url=redis://localhost:6379/0
# CW_BRIDGE__rate_limiting__redis_queue_key=cw_bridge:attentive_queue
# Max concurrent Chatwoot API calls per task (total = N_tasks × this value)
CW_BRIDGE__rate_limiting__max_chatwoot_concurrency=3
# Attentive webhook queue workers per task
CW_BRIDGE__rate_limiting__attentive_workers=3
# Max queued webhooks (memory mode only; Redis is unbounded)
CW_BRIDGE__rate_limiting__attentive_queue_size=5000
# Allowed Attentive event types (comma-separated). email.sent excluded by default.
CW_BRIDGE__rate_limiting__attentive_allowed_events=sms.sent,sms.inbound_message
# Contact cache TTL in seconds
CW_BRIDGE__rate_limiting__contact_cache_ttl=300
# Retry settings for Chatwoot API calls
CW_BRIDGE__rate_limiting__retry_max_attempts=3
CW_BRIDGE__rate_limiting__retry_base_delay=1.0

# -- Test-only (not read by config.py, used by test scripts) --
BRIDGE_BASE_URL=http://localhost:8009
KEYCLOAK_CLIENT_BASE_URL=http://localhost:8085
TEST_SMS_RECIPIENT=
TEST_EMAIL_RECIPIENT=
TEST_EMAIL_INBOX_ID=
TEST_GMAIL_SENDER=
TEST_CONTACT_NAME=Test User
TEST_LOOPMESSAGE_INBOX_ID=
TEST_LOOPMESSAGE_PHONE=
